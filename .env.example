# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FestivalFlow AI — .env.example
# 環境変数テンプレート（シークレット値は記載禁止）
# このファイルをコピーして .env を作成してください：
#   cp .env.example .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── セキュリティ ────────────────────────────────────────────
# JWT署名に使用するシークレットキー（本番環境では強力なランダム文字列を使用）
# 生成例: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-secure-random-jwt-secret-change-this-in-production

# bcrypt ラウンド数（本番推奨: 12、開発用: 4）
BCRYPT_ROUNDS=12

# ── 認証PIN（本番環境では Supabase Auth に差し替えること） ──
# 平文PINは .env で管理し、.gitignore で除外すること
STAFF_PIN=1234
ADMIN_PIN=9999

# ── Supabase 設定（オプション・バックエンド連携時のみ必要） ──
# Supabase プロジェクト URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon（公開）キー
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── アプリ設定 ──────────────────────────────────────────────
# アプリ環境（development / production）
APP_ENV=development

# デバッグモード（production では False に設定）
DEBUG=False

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 【重要な注意事項】
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 1. このファイルは .gitignore に含まれていません（テンプレートとして公開）
# 2. 実際の .env ファイルは必ず .gitignore で除外してください
# 3. Streamlit Cloud では .streamlit/secrets.toml で管理してください
# 4. 本番環境では JWT_SECRET を毎デプロイ時にローテーションすることを推奨します
